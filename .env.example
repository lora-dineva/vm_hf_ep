# Required
HF_TOKEN=your_hf_token

# Optional: override scene description endpoint (default in config.yaml)
# HF_ENDPOINT=https://your-endpoint.aws.endpoints.huggingface.cloud

# Optional: final description (merge/style) endpoint and model
# HF_FINAL_ENDPOINT=https://your-final-endpoint.aws.endpoints.huggingface.cloud
# HF_FINAL_MODEL=mistralai/Mistral-Nemo-Instruct-2407

# Langfuse (optional: prompt management and tracing)
# All prompts are fetched from Langfuse when these are set.
# Without Langfuse, hardcoded fallback prompts are used.
# LANGFUSE_SECRET_KEY=sk-lf-...
# LANGFUSE_PUBLIC_KEY=pk-lf-...
# LANGFUSE_BASE_URL=https://cloud.langfuse.com
